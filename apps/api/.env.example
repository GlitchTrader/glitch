WHOP_WEBHOOK_SECRET=
# Optional Whop webhook key. If set, this value is used directly.
# If not set, webhook key is derived from WHOP_WEBHOOK_SECRET using the Whop docs pattern.
WHOP_WEBHOOK_KEY=
WHOP_API_KEY=
DATABASE_URL=
LICENSE_KEY_HASH_SECRET=

# Stub switch for the temporary license endpoints.
# false = deny by default, true = allow all in stub responses.
LICENSE_STUB_ALLOW_ALL=false
