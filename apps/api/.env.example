WHOP_WEBHOOK_SECRET=
# Optional Whop webhook key. If set, this value is used directly.
# If not set, webhook key is derived from WHOP_WEBHOOK_SECRET using the Whop docs pattern.
WHOP_WEBHOOK_KEY=
WHOP_API_KEY=
# If your Postgres URL includes sslmode, prefer sslmode=verify-full.
# For libpq-compatible require semantics, append uselibpqcompat=true&sslmode=require.
DATABASE_URL=
LICENSE_KEY_HASH_SECRET=
ADMIN_API_TOKEN=
CRON_SECRET=
FINNHUB_API_KEY=
FRED_API_KEY=
# AddOn update metadata source (download app JSON endpoint).
ADDON_RELEASES_LATEST_URL=https://download.glitchtrader.com/api/releases/latest
# Optional emergency override; when set, this version wins over metadata URL above.
ADDON_LATEST_VERSION=
# Optional fallback download URL used if metadata lookup fails or payload omits a URL.
ADDON_LATEST_DOWNLOAD_URL=https://download.glitchtrader.com/latest
# Optional AI-channel emergency override and fallback. Used only by addon-ai-* clients.
ADDON_AI_LATEST_VERSION=
ADDON_AI_LATEST_DOWNLOAD_URL=https://download.glitchtrader.com/latest/ai

# Product-first mapping:
# - free product (or no license key in the AddOn) should behave like free_lite
# - any paid product should behave like premium, regardless of monthly/annual/lifetime billing
# - use raw Whop ids; the resolver also strips accidental pasted \r, \n, and \t escape sequences
WHOP_FREE_LITE_PRODUCT_IDS=prod_QX1HIqoZcBywS
WHOP_PREMIUM_PRODUCT_IDS=prod_nL5dDWWpEq9gF

# Billing-variant classification for display/reporting. Product IDs above remain the source of truth for plan access.
WHOP_FREE_LITE_PLAN_CODES=plan_IROhfJAbF79K6
WHOP_PREMIUM_MONTHLY_PLAN_CODES=plan_G81vTccV19dNA,plan_W6nOCfXPm7pka
WHOP_PREMIUM_ANNUAL_PLAN_CODES=plan_mQwXzPuHG04ec
WHOP_PREMIUM_LIFETIME_PLAN_CODES=plan_1W2MP7djClPpB
WHOP_PREMIUM_PLAN_CODES=plan_G81vTccV19dNA,plan_mQwXzPuHG04ec,plan_1W2MP7djClPpB,plan_W6nOCfXPm7pka
WHOP_STRICT_PLAN_MAPPING=true
WHOP_DEFAULT_ACTIVE_PLAN=free_lite
LICENSE_TOKEN_ES256_PRIVATE_KEY_PEM=
LICENSE_TOKEN_ES256_KID=
LICENSE_TOKEN_TTL_SECONDS=120
WEBHOOK_EVENT_RETENTION_DAYS=45
REVOKED_BINDING_RETENTION_DAYS=60
LICENSE_NONCE_RETENTION_SECONDS=1200
PROVIDER_PROXY_CACHE_RETENTION_SECONDS=86400
PROVIDER_PROXY_ACCESS_CACHE_SECONDS=30
LICENSE_VALIDATE_RATE_LIMIT_PER_MINUTE_IP=180
LICENSE_VALIDATE_RATE_LIMIT_PER_MINUTE_LICENSE=60
LICENSE_HEARTBEAT_RATE_LIMIT_PER_MINUTE_IP=360
LICENSE_HEARTBEAT_RATE_LIMIT_PER_MINUTE_LICENSE=120
PROVIDER_PROXY_RATE_LIMIT_PER_MINUTE_IP=1800
PROVIDER_PROXY_RATE_LIMIT_PER_MINUTE_LICENSE=900
FUNDAMENTALS_RATE_LIMIT_PER_MINUTE_IP=600
FUNDAMENTALS_RATE_LIMIT_PER_MINUTE_LICENSE=300
PROVIDER_PROXY_TTL_FINNHUB_QUOTE_SECONDS=90
PROVIDER_PROXY_TTL_FINNHUB_COMPANY_NEWS_SECONDS=300
PROVIDER_PROXY_TTL_FINNHUB_GENERAL_NEWS_SECONDS=300
PROVIDER_PROXY_TTL_FINNHUB_STOCK_METRIC_SECONDS=21600
PROVIDER_PROXY_TTL_FINNHUB_CALENDAR_EARNINGS_SECONDS=7200
