indicator("Sweep2Trade Pro [CHE]", shorttitle="S2T Pro", overlay=true)

// ====================== Regime Filter: Trend (T3 + R²) ======================
grpTrend        = "S2T Regime Filter"
t3Length        = input.int(4,     "T3 Length",            minval=1, step=1, group=grpTrend)
t3VolumeFactor  = input.float(0.7, "T3 Volume Factor",     minval=0, maxval=1, step=0.1, group=grpTrend)
r2Len           = input.int(100,   "R² Lookback",          minval=20, group=grpTrend)
r2Min           = input.float(0.20,"R² Minimum Threshold", step=0.01, minval=0.0, maxval=1.0, group=grpTrend)
useTrendFilter  = input.bool(true, "Regime Filter active", group=grpTrend)

calcT3(src, length, volumeFactor) =>
    xe1 = ta.ema(src, length)
    xe2 = ta.ema(xe1, length)
    xe3 = ta.ema(xe2, length)
    xe4 = ta.ema(xe3, length)
    xe5 = ta.ema(xe4, length)
    xe6 = ta.ema(xe5, length)
    c1 = volumeFactor
    c2 = c1 * 3
    c3 = c1 * 3
    c4 = c1
    xe6 * c4 + xe5 * -c3 + xe4 * c2 + xe3 * -c1 + xe2

t3Line = calcT3(hlc3, t3Length, t3VolumeFactor)
t3LineColor = t3Line < hlc3 ? color.green : color.red

plot(t3Line,   "S2T T3", t3LineColor, 2)

r  = ta.correlation(close, bar_index, r2Len)
r2 = math.pow(r, 2)

// --- TrendUp / TrendDown with explicit chains (instead of ta.rising/falling) ---
t3UpChain   = (t3Line > t3Line[1] and t3Line[1] > t3Line[2] and t3Line[2] > t3Line[3])
t3DownChain = (t3Line < t3Line[1] and t3Line[1] < t3Line[2] and t3Line[2] < t3Line[3])

trendUp   = close > t3Line and t3UpChain   and r2 > r2Min
trendDown = close < t3Line and t3DownChain and r2 > r2Min

// ====================== Inputs: Sweep/Sequence & Confirmation ======================
grpSeq     = "S2T Sweep/Sequence"
dipWindow  = input.int(8,  "Max bars for sequence (timeout)", minval=1, maxval=50, group=grpSeq)
extendTimeoutOnPhase2 = input.bool(true, "Restart timeout after T3 direction", group=grpSeq)
swingLook  = input.int(20, "Swing lookback for sweep (High/Low)", minval=5, group=grpSeq)

grpConfirm  = "S2T Confirmation"
bosLb       = input.int(5,   "BOS lookback (micro pivot)", minval=2, group=grpConfirm)
useWickBOS  = input.bool(true, "BOS: Wick is sufficient", group=grpConfirm)
requireBOS  = input.bool(true, "Require BOS", group=grpConfirm)
needT3Close = input.bool(true, "Require close above/below T3", group=grpConfirm)

// ====================== Sweep Definitions ======================
// Bullish sweep (for LONG): old low is briefly undercut, close returns above it
priorLowest   = ta.lowest(low,  swingLook)[1]
bullishSweep  = low < priorLowest and close > priorLowest
newBullish    = bullishSweep and not bullishSweep[1]

// Bearish sweep (for SHORT): old high is briefly exceeded, close returns below it
priorHighest  = ta.highest(high, swingLook)[1]
bearishSweep  = high > priorHighest and close < priorHighest
newBearish    = bearishSweep and not bearishSweep[1]

// ====================== Confirmation (BOS + Close + T3) ======================
// Long BOS above micro high
bosLevelHigh = ta.highest(high, bosLb)[1]
bosWickLong  = high > bosLevelHigh
bosCloseLong = ta.crossover(close, bosLevelHigh)
bosLong      = useWickBOS ? bosWickLong : bosCloseLong

// Short BOS below micro low
bosLevelLow  = ta.lowest(low, bosLb)[1]
bosWickShort = low < bosLevelLow
bosCloseShort= ta.crossunder(close, bosLevelLow)
bosShort     = useWickBOS ? bosWickShort : bosCloseShort

bullClose = close >= high - (high - low) * 0.25
bearClose = close <= low  + (high - low) * 0.25
aboveT3   = na(t3Line) ? true : close > t3Line
belowT3   = na(t3Line) ? true : close < t3Line

confirmLong  = (requireBOS ? bosLong  : true) and bullClose and (needT3Close ? aboveT3 : true)
confirmShort = (requireBOS ? bosShort : true) and bearClose and (needT3Close ? belowT3 : true)

// ====================== Sequence Locking (separate FSMs) ======================
// Phase 0: Idle
// Phase 1: Sweep detected (waits for T3 direction: ↑ for long / ↓ for short)
// Phase 2: T3 direction confirmed → show sweep signal; waits for confirmation
// Trade fires at Phase 2 ∧ Confirm ∧ (trend filter optional)

var int phaseL = 0
var int phaseS = 0
var int timeoutBarL = na
var int timeoutBarS = na

// Event 1: Sweep → Phase 1 + set timeout
if newBullish
    phaseL := 1
    timeoutBarL := bar_index + dipWindow
if newBearish
    phaseS := 1
    timeoutBarS := bar_index + dipWindow

// Timeout / reset per side
timedOutL = phaseL > 0 and not na(timeoutBarL) and bar_index > timeoutBarL
timedOutS = phaseS > 0 and not na(timeoutBarS) and bar_index > timeoutBarS
if timedOutL
    phaseL := 0
    timeoutBarL := na
if timedOutS
    phaseS := 0
    timeoutBarS := na

// Event 2: T3 direction?
t3Up   = t3Line > t3Line[1]
t3Down = t3Line < t3Line[1]

// Event 3: Phase 1 + T3 direction → Phase 2, optionally restart timeout
sweepSignalLong  = phaseL == 1 and t3Up
sweepSignalShort = phaseS == 1 and t3Down
if sweepSignalLong
    phaseL := 2
    if extendTimeoutOnPhase2
        timeoutBarL := bar_index + dipWindow
if sweepSignalShort
    phaseS := 2
    if extendTimeoutOnPhase2
        timeoutBarS := bar_index + dipWindow

// Event 4 (Trades): Phase 2 + confirm (+ optional trend filter) → signal, then reset
canBuy   = phaseL == 2 and confirmLong  and (useTrendFilter ? trendUp   : true)
canSell  = phaseS == 2 and confirmShort and (useTrendFilter ? trendDown : true)
buySignal  = canBuy
sellSignal = canSell
if canBuy
    phaseL := 0
    timeoutBarL := na
if canSell
    phaseS := 0
    timeoutBarS := na

// ====================== Plots ======================
plotshape(sweepSignalLong,  title="S2T SWEEP Long (bullish) cleared",  style=shape.xcross,       location=location.belowbar, size=size.tiny,  color=color.new(color.aqua, 0),   text="SWEEP L OK")
plotshape(buySignal,        title="S2T BUY Signal",                     style=shape.triangleup,   location=location.belowbar, size=size.small, color=color.new(color.lime, 0),  text="BUY")

plotshape(sweepSignalShort, title="S2T SWEEP Short (bearish) cleared",  style=shape.xcross,       location=location.abovebar, size=size.tiny,  color=color.new(color.fuchsia,0), text="SWEEP S OK")
plotshape(sellSignal,       title="S2T SELL Signal",                    style=shape.triangledown, location=location.abovebar, size=size.small, color=color.new(color.red, 0),    text="SELL")

// ====================== Alerts ======================
alertcondition(buySignal,        title="S2T Pro [CHE] BUY: Sequence complete",     message="S2T Pro [CHE] – BUY: Bullish sweep → T3↑ → confirmation (trend filter possibly active).")
alertcondition(sweepSignalLong,  title="S2T Pro [CHE] SWEEP Long (bullish)",       message="S2T Pro [CHE] – SWEEP LONG (bullish) cleared (T3 rising).")
alertcondition(sellSignal,       title="S2T Pro [CHE] SELL: Sequence complete",    message="S2T Pro [CHE] – SELL: Bearish sweep → T3↓ → confirmation (trend filter possibly active).")
alertcondition(sweepSignalShort, title="S2T Pro [CHE] SWEEP Short (bearish)",      message="S2T Pro [CHE] – SWEEP SHORT (bearish) cleared (T3 falling).")
