//@version=5
indicator(title="Adaptive Bollinger-RSI Trend Signal [CHE]", shorttitle="ABRT Signal [CHE]", overlay=true)

// Input Parameters
use_t3 = input.bool(false, title="Use T3 Instead of SMA") // Option to use T3 instead of SMA
t3_length = input.int(5, title="T3 Length") // Length for T3 calculation
t3_volume_factor = input.float(0.7, title="T3 Volume Factor") // Volume factor for T3 calculation
rsi_upper_threshold = input(65, title="RSI Upper Threshold") // Upper threshold for RSI
rsi_lower_threshold = input(35, title="RSI Lower Threshold") // Lower threshold for RSI
bb_length = input(20, title="Bollinger Bands Length") // Length for Bollinger Bands SMA
bb_src = input.source(close, title="Bollinger Bands Source") // Source for Bollinger Bands calculation
bb_mult = input.float(2.0, title="Bollinger Bands Multiplier") // Multiplier for Bollinger Bands deviation
rsi_length = input(14, title="RSI Length") // Length for RSI calculation
rsi_src = input.source(close, title="RSI Source") // Source for RSI calculation
cross_src = input.source(close, title="Crossover/Crossunder Source") // Source for crossover and crossunder conditions
show_table_label = input(true, title="Show Table Label") // Boolean to show/hide the table label

// Color Inputs
color_basis = input.color(color.blue, title="Basis Line Color")
color_upper = input.color(color.red, title="Upper Band Color")
color_lower = input.color(color.green, title="Lower Band Color")
color_fill = input.color(color.rgb(173, 216, 230, 90), title="Fill Color")
color_sell_label = input.color(color.red, title="Sell Label Color")
color_buy_label = input.color(color.green, title="Buy Label Color")
color_table_label_bg = input.color(color.black, title="Table Label Background Color")
color_table_label_text = input.color(color.white, title="Table Label Text Color")

// Function to calculate T3
t3(src, length, volumeFactor) =>
    e1 = ta.ema(src, length)
    e2 = ta.ema(e1, length)
    e3 = ta.ema(e2, length)
    e4 = ta.ema(e3, length)
    e5 = ta.ema(e4, length)
    e6 = ta.ema(e5, length)
    c1 = -volumeFactor * volumeFactor * volumeFactor
    c2 = 3 * volumeFactor * volumeFactor + 3 * volumeFactor * volumeFactor * volumeFactor
    c3 = -6 * volumeFactor * volumeFactor - 3 * volumeFactor - 3 * volumeFactor * volumeFactor * volumeFactor
    c4 = 1 + 3 * volumeFactor + volumeFactor * volumeFactor * volumeFactor + 3 * volumeFactor * volumeFactor
    t3_value = c1 * e6 + c2 * e5 + c3 * e4 + c4 * e3
    t3_value

// Bollinger Bands Calculation
basis = use_t3 ? t3(bb_src, t3_length, t3_volume_factor) : ta.sma(bb_src, bb_length) // T3 or SMA basis
dev = bb_mult * ta.stdev(bb_src, bb_length) // Standard deviation for Bollinger Bands
upper = basis + dev // Upper Bollinger Band
lower = basis - dev // Lower Bollinger Band

// Plotting Bollinger Bands
plot(basis, color=color_basis, linewidth=1)
p1 = plot(upper, color=color_upper, linewidth=1)
p2 = plot(lower, color=color_lower, linewidth=1)
fill(p1, p2, color=color_fill) // Filling between upper and lower bands

// RSI Calculation
rsi = ta.rsi(rsi_src, rsi_length) // Calculating RSI

// State Variables Initialization
var bool upper_cross = false // State to track if price crosses above upper Bollinger Band
var bool lower_cross = false // State to track if price crosses below lower Bollinger Band
var bool basis_up = false // State to track if the basis is increasing
var bool rsi_crossunder = false // State to track if RSI crosses under the upper threshold
var bool rsi_crossover = false // State to track if RSI crosses over the lower threshold
var int sell_count = 0 // Counter for Sell signals
var int buy_count = 0 // Counter for Buy signals
var float sell_sum = 0.0 // Sum of close prices for Sell signals
var float buy_sum = 0.0 // Sum of close prices for Buy signals

// Determine if basis is increasing or not
if (basis > basis[1])
    basis_up := true
else
    basis_up := false

// Trigger Conditions for Basis Changes
basis_trigger_sell = not basis_up and basis_up[1] // Condition when basis changes from increasing to decreasing
basis_trigger_buy = basis_up and not basis_up[1] // Condition when basis changes from decreasing to increasing

// Crossover and Crossunder States
if (ta.crossover(cross_src, upper))
    upper_cross := true
if (ta.crossunder(cross_src, lower))
    lower_cross := true

if (ta.crossunder(rsi, rsi_upper_threshold))
    rsi_crossunder := true
if (ta.crossover(rsi, rsi_lower_threshold))
    rsi_crossover := true

// Alerts für Kauf- und Verkaufssignale
alertcondition(upper_cross and rsi_crossunder and basis_trigger_sell, title="Sell Alert", message="Sell Signal Triggered")
alertcondition(lower_cross and rsi_crossover and basis_trigger_buy, title="Buy Alert", message="Buy Signal Triggered")

// Conditions for Signals
if (upper_cross and rsi_crossunder and basis_trigger_sell)
    sell_count := sell_count + 1
    sell_sum := sell_sum + close
    label.new(x=bar_index, y=high, text="Sell " + str.tostring(sell_count), style=label.style_label_down, color=color_sell_label, textcolor=color.white)
    upper_cross := false
    rsi_crossunder := false
    buy_count := 0 // Reset buy counter when a sell signal is generated
    buy_sum := 0.0 // Reset buy sum when a sell signal is generated
    alert("Sell Signal Triggered", alert.freq_once_per_bar) // Trigger Sell Alert

if (lower_cross and rsi_crossover and basis_trigger_buy)
    buy_count := buy_count + 1
    buy_sum := buy_sum + close
    label.new(x=bar_index, y=low, text="Buy " + str.tostring(buy_count), style=label.style_label_up, color=color_buy_label, textcolor=color.white)
    lower_cross := false
    rsi_crossover := false
    sell_count := 0 // Reset sell counter when a buy signal is generated
    sell_sum := 0.0 // Reset sell sum when a buy signal is generated
    alert("Buy Signal Triggered", alert.freq_once_per_bar) // Trigger Buy Alert

// Calculating DCA
sell_dca = na(sell_count) or sell_count == 0 ? 0 : math.round(sell_sum / sell_count)
buy_dca = na(buy_count) or buy_count == 0 ? 0 : math.round(buy_sum / buy_count)

// Displaying Position Count and DCA
if (show_table_label) 
    var label table_label = na

    if (not na(table_label))
        label.delete(table_label)

    table_label := label.new(x=bar_index, y=high + 10, text="Sell Count: " + str.tostring(sell_count) + "\nSell DCA: " + str.tostring(sell_dca) + "\nBuy Count: " + str.tostring(buy_count) + "\nBuy DCA: " + str.tostring(buy_dca), style=label.style_label_left, color=color_table_label_bg, textcolor=color_table_label_text, size=size.small)
