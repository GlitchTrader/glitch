    label.new(bar_index, low - label_offset_val, txt_sb, style=label.style_label_up, color=color.new(color.red, 40), textcolor=color.white, size=size.small)

// Hidden plots for alerts — Re-Entry (plot_0..5)
plot(fire_long ? sl_price_long : na, "SL Long", color=na, display=display.none)
