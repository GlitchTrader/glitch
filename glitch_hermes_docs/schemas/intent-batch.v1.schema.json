{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Glitch configured-group intent batch v1",
  "type": "object",
  "required": ["schema_version", "cycle_id", "decisions"],
  "properties": {
    "schema_version": { "const": "glitch.intent.batch.v1" },
    "cycle_id": { "type": "string", "minLength": 1 },
    "next_review_seconds": { "enum": [60, 300] },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "object" }
    }
  },
  "additionalProperties": false
}
