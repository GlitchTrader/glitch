{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Glitch Trade Intent v2 (bracket-mandatory)",
  "type": "object",
  "required": [
    "schema_version",
    "intent_id",
    "created_utc",
    "instrument",
    "account",
    "operator_profile",
    "action",
    "confidence",
    "snapshot_hash",
    "model_version",
    "prompt_version",
    "reason",
    "decision_audit"
  ],
  "properties": {
    "schema_version": {
      "const": "glitch.intent.v2"
    },
    "intent_id": {
      "type": "string",
      "description": "UUID; firewall enforces idempotency on this."
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "instrument": {
      "type": "string",
      "description": "Instrument root, e.g. MNQ. Must be in the firewall allowlist."
    },
    "account": {
      "type": "string",
      "description": "Target account name. Must be in the firewall allowlist."
    },
    "operator_profile": {
      "type": "string",
      "description": "Hermes profile identity. Glitch binds this value to exactly one group master account."
    },
    "action": {
      "enum": [
        "ENTER_LONG",
        "ENTER_SHORT",
        "HOLD",
        "MOVE_STOP",
        "MOVE_TP",
        "EXIT",
        "NOTHING"
      ],
      "description": "ENTER actions create independently protected tranches. MOVE_STOP tightens native stops. MOVE_TP moves every remaining native target and may also tighten stops."
    },
    "quantity": {
      "type": "integer",
      "minimum": 0,
      "description": "Required > 0 for ENTER_*. Must be one of the valid group quantities derived from account ceilings, open exposure, and ratios."
    },
    "order_type": {
      "const": "MARKET",
      "description": "The current executor is market-only. Structural stops and targets remain absolute prices."
    },
    "stop_loss": {
      "type": [
        "number",
        "null"
      ],
      "description": "MANDATORY for ENTER_*. Optional on MOVE_TP to tighten every remaining stop. Loss side of market, tick-rounded."
    },
    "take_profit_1": {
      "type": [
        "number",
        "null"
      ],
      "description": "MANDATORY for ENTER_* and MOVE_TP. On MOVE_TP, replaces every remaining target. Profit side of live market, tick-rounded."
    },
    "take_profit_2": {
      "type": [
        "number",
        "null"
      ],
      "description": "Optional runner target beyond TP1. Requires quantity >= 2 and quantity_tp1."
    },
    "stop_loss_2": {
      "type": [
        "number",
        "null"
      ],
      "description": "Optional initial stop for the TP2 runner leg. Must remain on the loss side of entry and be tighter than stop_loss. Requires take_profit_2."
    },
    "quantity_tp1": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "description": "Contracts closed at TP1 when TP2 present. Remainder (quantity - quantity_tp1 >= 1) runs to TP2."
    },
    "take_profit_3": {
      "type": [
        "number",
        "null"
      ],
      "description": "Optional third target beyond TP2. Requires quantity >= 3, quantity_tp1, and quantity_tp2."
    },
    "stop_loss_3": {
      "type": [
        "number",
        "null"
      ],
      "description": "Optional initial stop for the TP3 leg. Must remain on the loss side and be tighter than the preceding stop."
    },
    "quantity_tp2": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "description": "Contracts closed at TP2 when TP3 is present. The remaining contracts run to TP3."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string",
      "description": "Human-readable rationale; journaled verbatim."
    },
    "snapshot_hash": {
      "type": "string",
      "description": "Hash of the telemetry snapshot the decision was based on. Firewall enforces the configured freshness window."
    },
    "model_version": {
      "type": "string"
    },
    "prompt_version": {
      "type": "string"
    },
    "decision_audit": {
      "type": "object",
      "required": [
        "bull_case",
        "bear_case",
        "flat_case",
        "aggressive_case",
        "conservative_case",
        "decisive_evidence",
        "disconfirming_evidence",
        "change_condition",
        "final_choice"
      ],
      "properties": {
        "bull_case": { "type": "string", "maxLength": 500 },
        "bear_case": { "type": "string", "maxLength": 500 },
        "flat_case": { "type": "string", "maxLength": 500 },
        "aggressive_case": { "type": "string", "maxLength": 500 },
        "conservative_case": { "type": "string", "maxLength": 500 },
        "decisive_evidence": { "type": "string", "maxLength": 500 },
        "disconfirming_evidence": { "type": "string", "maxLength": 500 },
        "change_condition": { "type": "string", "maxLength": 500 },
        "final_choice": {
          "enum": ["ENTER_LONG", "ENTER_SHORT", "HOLD", "MOVE_STOP", "MOVE_TP", "EXIT", "NOTHING"]
        }
      },
      "additionalProperties": false,
      "description": "Compact adversarial evidence audit; not a chain-of-thought transcript. final_choice must match action and is checked by the external validator."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "ENTER_LONG",
              "ENTER_SHORT"
            ]
          }
        }
      },
      "then": {
        "required": [
          "quantity",
          "order_type",
          "stop_loss",
          "take_profit_1"
        ],
        "properties": {
          "quantity": {
            "minimum": 1
          },
          "stop_loss": {
            "type": "number"
          },
          "take_profit_1": {
            "type": "number"
          }
        }
      }
    },
    {
      "if": {
        "properties": { "action": { "const": "MOVE_STOP" } }
      },
      "then": {
        "required": ["stop_loss"],
        "properties": { "stop_loss": { "type": "number" } }
      }
    },
    {
      "if": {
        "required": [
          "take_profit_2"
        ],
        "properties": {
          "take_profit_2": {
            "type": "number"
          }
        }
      },
      "then": {
        "required": [
          "quantity_tp1"
        ],
        "properties": {
          "quantity": {
            "minimum": 2
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "stop_loss_2"
        ],
        "properties": {
          "stop_loss_2": {
            "type": "number"
          }
        }
      },
      "then": {
        "required": [
          "take_profit_2"
        ],
        "properties": {
          "take_profit_2": {
            "type": "number"
          }
        }
      }
    },
    {
      "if": {
        "properties": { "action": { "const": "MOVE_TP" } }
      },
      "then": {
        "required": ["take_profit_1"],
        "properties": {
          "take_profit_1": { "type": "number" },
          "stop_loss": { "type": "number" }
        }
      }
    },
    {
      "if": {
        "required": [
          "take_profit_3"
        ],
        "properties": {
          "take_profit_3": {
            "type": "number"
          }
        }
      },
      "then": {
        "required": [
          "take_profit_2",
          "quantity_tp1",
          "quantity_tp2"
        ],
        "properties": {
          "quantity": {
            "minimum": 3
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "stop_loss_3"
        ],
        "properties": {
          "stop_loss_3": {
            "type": "number"
          }
        }
      },
      "then": {
        "required": [
          "take_profit_3"
        ],
        "properties": {
          "take_profit_3": {
            "type": "number"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
